{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typegen": "npx pocketbase-typegen --db ../server/pb_data/data.db --out ./src/pb_types.ts",
    "test": "vitest"
  },
  "devDependencies": {
    "happy-dom": "^20.8.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-static-copy": "^3.1.5",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3",
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  },
  "dependencies": {
    "@ionic/core": "^8.7.17",
    "dompurify": "^3.3.1",
    "lit-html": "^3.3.2",
    "marked": "^17.0.1",
    "pocketbase": "^0.26.6",
    "solit-html": "github:duncsully/solit-html"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
